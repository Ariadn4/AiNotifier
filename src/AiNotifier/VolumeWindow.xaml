<Window x:Class="AiNotifier.VolumeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Volume slider -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="VolumeLabel2" FontSize="13" FontWeight="SemiBold"
                       Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Text="🔈" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <Slider x:Name="VolumeSlider" Width="160" Minimum="0" Maximum="1"
                    VerticalAlignment="Center" SmallChange="0.05" LargeChange="0.1"
                    IsSnapToTickEnabled="True" TickFrequency="0.05"/>
            <TextBlock x:Name="VolumeLabel" FontSize="12" Foreground="#6b7280"
                       VerticalAlignment="Center" Margin="8,0,0,0" Width="32"
                       TextAlignment="Right"/>
        </StackPanel>

        <!-- Gradual volume checkbox -->
        <CheckBox x:Name="GradualVolumeCheck" Grid.Row="1"
                  FontSize="12" Foreground="#374151" Margin="0,0,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelBtn" Width="70" Height="30"
                    Click="Cancel_Click"
                    Background="#f3f4f6" Foreground="#6b7280"
                    BorderBrush="#d1d5db" BorderThickness="1"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button x:Name="OKBtn" Width="70" Height="30"
                    Click="OK_Click"
                    Background="#0284c7" Foreground="White"
                    BorderBrush="#0284c7" BorderThickness="1"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
