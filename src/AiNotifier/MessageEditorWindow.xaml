<Window x:Class="AiNotifier.MessageEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑提醒消息"
        Width="360" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="每行一条提醒消息："
                   Foreground="#6b7280" FontSize="12" Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" x:Name="MessagesBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#f9fafb"
                 Foreground="#374151"
                 BorderBrush="#d1d5db"
                 BorderThickness="1"
                 Padding="8,6"
                 FontSize="13"
                 CaretBrush="#0284c7"/>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Button Content="恢复默认" Height="30"
                    HorizontalAlignment="Left"
                    Click="Reset_Click"
                    Background="#f3f4f6" Foreground="#6b7280"
                    BorderBrush="#d1d5db" BorderThickness="1"
                    Cursor="Hand" Padding="12,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="70" Height="30"
                        Click="Cancel_Click"
                        Background="#f3f4f6" Foreground="#6b7280"
                        BorderBrush="#d1d5db" BorderThickness="1"
                        Cursor="Hand" Margin="0,0,8,0"/>
                <Button Content="确定" Width="70" Height="30"
                        Click="OK_Click"
                        Background="#0284c7" Foreground="White"
                        BorderBrush="#0284c7" BorderThickness="1"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
