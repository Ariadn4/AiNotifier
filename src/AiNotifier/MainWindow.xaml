<Window x:Class="AiNotifier.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="96" Height="96"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- ═══ Context Menu Light Theme ═══ -->
        <Style x:Key="LightContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.15" Color="Black"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Icon" Margin="0,0,8,0"
                                                  VerticalAlignment="Center" Width="15" Height="15"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock x:Name="CheckMark" Grid.Column="2" Text="✓" Margin="8,0,0,0"
                                           Foreground="#0284c7" FontWeight="Bold" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsCheckable" Value="False">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightSeparator" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="#E2E8F0" Height="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerMenuItem" TargetType="MenuItem" BasedOn="{StaticResource LightMenuItem}">
            <Setter Property="Foreground" Value="#DC2626"/>
        </Style>

        <!-- Submenu parent item (has children with popup) -->
        <Style x:Key="LightSubmenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" ContentSource="Icon" Margin="0,0,8,0"
                                                      VerticalAlignment="Center" Width="15" Height="15"/>
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Grid.Column="2" Text="▸" Margin="8,0,0,0"
                                               Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right" HorizontalOffset="-2" VerticalOffset="-6"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                                        CornerRadius="10" Padding="4" Margin="8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.12" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Light Slider with Round Thumb ═══ -->
        <Style x:Key="RoundSliderThumb" TargetType="Thumb"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="#0284c7" Width="14" Height="14"
                                 Stroke="#0369A1" StrokeThickness="1.5"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightSlider" TargetType="Slider">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="#E2E8F0"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource RoundSliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Animations ═══ -->

        <!-- Eye blink for ON state (~3.8s cycle) -->
        <Storyboard x:Key="EyeBlinkStory" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OnEyeScale" Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.6" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.67" Value="0.1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:1.75" Value="1"/>
                <LinearDoubleKeyFrame KeyTime="0:0:3.8" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Antenna glow for ON state (2.5s) -->
        <Storyboard x:Key="AntennaGlowStory" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="OnAntennaTip" Storyboard.TargetProperty="Opacity"
                             From="0.5" To="1.0" Duration="0:0:1.25"/>
        </Storyboard>

        <!-- Ball wiggle for ALERT state -->
        <Storyboard x:Key="WiggleStory" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BallRotate" Storyboard.TargetProperty="Angle"
                             From="-4" To="4" Duration="0:0:0.35"/>
            <DoubleAnimation Storyboard.TargetName="BallWiggleScale" Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="1.04" Duration="0:0:0.35"/>
            <DoubleAnimation Storyboard.TargetName="BallWiggleScale" Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="1.04" Duration="0:0:0.35"/>
        </Storyboard>

        <!-- Ripple rings for ALERT state -->
        <Storyboard x:Key="RippleStory" RepeatBehavior="Forever">
            <!-- Ripple 1 -->
            <DoubleAnimation Storyboard.TargetName="Ripple1Scale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="2.3" Duration="0:0:1.2" BeginTime="0:0:0"/>
            <DoubleAnimation Storyboard.TargetName="Ripple1Scale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="2.3" Duration="0:0:1.2" BeginTime="0:0:0"/>
            <DoubleAnimation Storyboard.TargetName="Ripple1" Storyboard.TargetProperty="Opacity"
                             From="0.55" To="0" Duration="0:0:1.2" BeginTime="0:0:0"/>
            <!-- Ripple 2 -->
            <DoubleAnimation Storyboard.TargetName="Ripple2Scale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="2.3" Duration="0:0:1.2" BeginTime="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="Ripple2Scale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="2.3" Duration="0:0:1.2" BeginTime="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="Ripple2" Storyboard.TargetProperty="Opacity"
                             From="0.55" To="0" Duration="0:0:1.2" BeginTime="0:0:0.4"/>
            <!-- Ripple 3 -->
            <DoubleAnimation Storyboard.TargetName="Ripple3Scale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="2.3" Duration="0:0:1.2" BeginTime="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetName="Ripple3Scale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="2.3" Duration="0:0:1.2" BeginTime="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetName="Ripple3" Storyboard.TargetProperty="Opacity"
                             From="0.55" To="0" Duration="0:0:1.2" BeginTime="0:0:0.8"/>
        </Storyboard>

        <!-- Antenna flash for ALERT state -->
        <Storyboard x:Key="AntennaFlashStory" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="AlertAntennaTip" Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1.0" Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu Style="{StaticResource LightContextMenu}" Opened="ContextMenu_Opened">
            <MenuItem x:Name="MenuToggleAlert" Header="开启提醒" Style="{StaticResource LightSubmenuItem}">
                <MenuItem.Icon>
                    <Path Data="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9 M13.73 21a2 2 0 0 1-3.46 0"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
                <MenuItem Header="_" Visibility="Collapsed"/>
            </MenuItem>
            <MenuItem x:Name="MenuProjectBubble" Header="提醒日志"
                      IsCheckable="True"
                      Style="{StaticResource LightMenuItem}"
                      Click="MenuProjectBubble_Click">
                <MenuItem.Icon>
                    <Path Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Style="{StaticResource LightSeparator}"/>
            <!-- 声音设置 -->
            <MenuItem x:Name="MenuSoundSettings" Header="提示音效"
                      Style="{StaticResource LightMenuItem}"
                      Click="MenuSoundSettings_Click">
                <MenuItem.Icon>
                    <Path Data="M9 18V5l12-2v13 M6 18a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M18 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="MenuVolume" Header="音量"
                      Style="{StaticResource LightMenuItem}"
                      Click="MenuVolume_Click">
                <MenuItem.Icon>
                    <Path Data="M11 5L6 9H2v6h4l5 4V5z M15.54 8.46a5 5 0 0 1 0 7.07"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Style="{StaticResource LightSeparator}"/>
            <!-- 提醒模式 -->
            <MenuItem x:Name="MenuShortMode" Header="短提醒模式"
                      IsCheckable="True"
                      Style="{StaticResource LightMenuItem}"
                      Click="MenuShortMode_Click">
                <MenuItem.Icon>
                    <Path Data="M12 2L12 12L16 14 M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="MenuAlertTimeout" Header="长提醒时长" Style="{StaticResource LightSubmenuItem}">
                <MenuItem.Icon>
                    <Path Data="M22 12A10 10 0 1 1 12 2 M12 6v6l4 2"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
                <MenuItem Header="_" Visibility="Collapsed"/>
            </MenuItem>
            <Separator Style="{StaticResource LightSeparator}"/>
            <!-- 其他设置 -->
            <MenuItem x:Name="MenuNudge" Header="碎碎念" Style="{StaticResource LightSubmenuItem}">
                <MenuItem.Icon>
                    <Path Data="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
                <MenuItem Header="_" Visibility="Collapsed"/>
            </MenuItem>
            <MenuItem x:Name="MenuBindClaude" Header="绑定 Claude Code"
                      IsCheckable="True"
                      Style="{StaticResource LightMenuItem}"
                      Click="MenuBindClaude_Click">
                <MenuItem.Icon>
                    <Path Data="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71 M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="MenuAutoStart" Header="开机自启动"
                      IsCheckable="True"
                      Style="{StaticResource LightMenuItem}"
                      Click="MenuAutoStart_Click">
                <MenuItem.Icon>
                    <Path Data="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z M2 12h20"
                          Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="MenuLanguage" Header="语言" Style="{StaticResource LightSubmenuItem}">
                <MenuItem.Icon>
                    <Path Data="M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0014.07 6H17V4h-7V2H8v2H1v2h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z"
                          Fill="#64748B" Stretch="Uniform"/>
                </MenuItem.Icon>
                <MenuItem Header="_" Visibility="Collapsed"/>
            </MenuItem>
            <Separator Style="{StaticResource LightSeparator}"/>
            <MenuItem x:Name="MenuExit" Header="退出" Style="{StaticResource DangerMenuItem}" Click="MenuExit_Click">
                <MenuItem.Icon>
                    <Path Data="M18.36 6.64a9 9 0 1 1-12.73 0 M12 2v10"
                          Stroke="#DC2626" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </Window.ContextMenu>

    <Grid>
        <Grid.Clip>
            <EllipseGeometry Center="48,48" RadiusX="48" RadiusY="48"/>
        </Grid.Clip>
        <!-- Ripple rings (ALERT only) — stroke color set dynamically per alert type -->
        <Ellipse x:Name="Ripple1" Width="72" Height="72" StrokeThickness="2"
                 Fill="Transparent" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.Stroke><SolidColorBrush x:Name="Ripple1Brush" Color="#fbbf24"/></Ellipse.Stroke>
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="Ripple1Scale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="Ripple2" Width="72" Height="72" StrokeThickness="2"
                 Fill="Transparent" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.Stroke><SolidColorBrush x:Name="Ripple2Brush" Color="#fbbf24"/></Ellipse.Stroke>
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="Ripple2Scale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>
        <Ellipse x:Name="Ripple3" Width="72" Height="72" StrokeThickness="2"
                 Fill="Transparent" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.Stroke><SolidColorBrush x:Name="Ripple3Brush" Color="#fbbf24"/></Ellipse.Stroke>
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="Ripple3Scale" ScaleX="1" ScaleY="1"/>
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Ball container with wiggle transform -->
        <Grid x:Name="BallContainer" Width="72" Height="72"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5"
              MouseEnter="Ball_MouseEnter" MouseLeave="Ball_MouseLeave">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="BallWiggleScale" ScaleX="1" ScaleY="1"/>
                    <RotateTransform x:Name="BallRotate" Angle="0"/>
                    <ScaleTransform x:Name="BallHoverScale" ScaleX="1" ScaleY="1"/>
                </TransformGroup>
            </Grid.RenderTransform>
            <Grid.ToolTip>
                <ToolTip x:Name="BallTooltip" Content="监听中"/>
            </Grid.ToolTip>

            <!-- Ball background -->
            <Ellipse x:Name="Ball" Width="72" Height="72">
                <Ellipse.Fill>
                    <RadialGradientBrush x:Name="BallGradient" GradientOrigin="0.38,0.30" Center="0.38,0.30">
                        <GradientStop x:Name="GradientInner" Color="#7dd3fc" Offset="0"/>
                        <GradientStop x:Name="GradientOuter" Color="#0284c7" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect x:Name="BallShadow" BlurRadius="20" ShadowDepth="4" Opacity="0.4"
                                      Color="#38bdf8" Direction="270"/>
                </Ellipse.Effect>
            </Ellipse>

            <!-- Robot character -->
            <Viewbox Width="46" Height="46" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,0,0,2">
                <Canvas Width="100" Height="80" ClipToBounds="False">

                    <!-- ═══ Shared structural elements ═══ -->

                    <!-- Antenna stem -->
                    <Line x:Name="AntennaStem" X1="50" Y1="18" X2="50" Y2="6"
                          Stroke="White" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                    <!-- ON antenna tip -->
                    <Ellipse x:Name="OnAntennaTip" Canvas.Left="46" Canvas.Top="0" Width="8" Height="8"
                             Fill="#bae6fd" Opacity="0.75"/>

                    <!-- ALERT antenna tip — fill color set dynamically per alert type -->
                    <Ellipse x:Name="AlertAntennaTip" Canvas.Left="45" Canvas.Top="-1" Width="10" Height="10"
                             Opacity="0" Visibility="Collapsed">
                        <Ellipse.Fill><SolidColorBrush x:Name="AlertAntennaBrush" Color="#fef08a"/></Ellipse.Fill>
                    </Ellipse>

                    <!-- OFF antenna tip -->
                    <Ellipse x:Name="OffAntennaTip" Canvas.Left="46" Canvas.Top="0" Width="8" Height="8"
                             Fill="White" Opacity="0" Visibility="Collapsed"/>

                    <!-- Head -->
                    <Rectangle x:Name="Head" Canvas.Left="24" Canvas.Top="18" Width="52" Height="42"
                               RadiusX="14" RadiusY="14" Fill="White" Opacity="0.95"/>

                    <!-- Left ear -->
                    <Rectangle x:Name="LeftEar" Canvas.Left="14" Canvas.Top="30" Width="10" Height="16"
                               RadiusX="5" RadiusY="5" Fill="White" Opacity="0.8"/>

                    <!-- Right ear -->
                    <Rectangle x:Name="RightEar" Canvas.Left="76" Canvas.Top="30" Width="10" Height="16"
                               RadiusX="5" RadiusY="5" Fill="White" Opacity="0.8"/>

                    <!-- Body -->
                    <Rectangle x:Name="Body" Canvas.Left="36" Canvas.Top="62" Width="28" Height="14"
                               RadiusX="7" RadiusY="7" Fill="White" Opacity="0.7"/>

                    <!-- Body dots (change color per state) -->
                    <Ellipse x:Name="BodyDot1" Canvas.Left="42" Canvas.Top="67" Width="4" Height="4" Opacity="0.5">
                        <Ellipse.Fill><SolidColorBrush x:Name="Dot1Brush" Color="#0284c7"/></Ellipse.Fill>
                    </Ellipse>
                    <Ellipse x:Name="BodyDot2" Canvas.Left="48" Canvas.Top="67" Width="4" Height="4" Opacity="0.5">
                        <Ellipse.Fill><SolidColorBrush x:Name="Dot2Brush" Color="#38bdf8"/></Ellipse.Fill>
                    </Ellipse>
                    <Ellipse x:Name="BodyDot3" Canvas.Left="54" Canvas.Top="67" Width="4" Height="4" Opacity="0.5">
                        <Ellipse.Fill><SolidColorBrush x:Name="Dot3Brush" Color="#0284c7"/></Ellipse.Fill>
                    </Ellipse>

                    <!-- ═══ ON State Face ═══ -->
                    <Canvas x:Name="RobotOn" Visibility="Visible">
                        <!-- Eyes with blink transform -->
                        <Canvas RenderTransformOrigin="0.5,0.5" Canvas.Left="0" Canvas.Top="0">
                            <Canvas.RenderTransform>
                                <ScaleTransform x:Name="OnEyeScale" ScaleX="1" ScaleY="1" CenterX="50" CenterY="38"/>
                            </Canvas.RenderTransform>
                            <!-- Left eye -->
                            <Ellipse Canvas.Left="31.5" Canvas.Top="31" Width="13" Height="14" Fill="#0284c7"/>
                            <Ellipse Canvas.Left="33.8" Canvas.Top="33.3" Width="4.4" Height="4.4" Fill="White" Opacity="0.65"/>
                            <!-- Right eye -->
                            <Ellipse Canvas.Left="55.5" Canvas.Top="31" Width="13" Height="14" Fill="#0284c7"/>
                            <Ellipse Canvas.Left="57.8" Canvas.Top="33.3" Width="4.4" Height="4.4" Fill="White" Opacity="0.65"/>
                        </Canvas>

                        <!-- Blush -->
                        <Ellipse Canvas.Left="22" Canvas.Top="45" Width="12" Height="6" Fill="#fda4af" Opacity="0.35"/>
                        <Ellipse Canvas.Left="66" Canvas.Top="45" Width="12" Height="6" Fill="#fda4af" Opacity="0.35"/>

                        <!-- Smile -->
                        <Path Data="M38,50 Q50,60 62,50" Stroke="#0284c7" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                    </Canvas>

                    <!-- ═══ ALERT State Face ═══ (colors set dynamically per alert type) -->
                    <Canvas x:Name="RobotAlert" Visibility="Collapsed">
                        <!-- Left eye - surprised -->
                        <Ellipse Canvas.Left="31" Canvas.Top="31" Width="14" Height="14">
                            <Ellipse.Fill><SolidColorBrush x:Name="AlertLeftEyeBrush" Color="#d97706"/></Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Canvas.Left="34.5" Canvas.Top="34.5" Width="7" Height="7" Fill="White"/>
                        <!-- Right eye - surprised -->
                        <Ellipse Canvas.Left="55" Canvas.Top="31" Width="14" Height="14">
                            <Ellipse.Fill><SolidColorBrush x:Name="AlertRightEyeBrush" Color="#d97706"/></Ellipse.Fill>
                        </Ellipse>
                        <Ellipse Canvas.Left="58.5" Canvas.Top="34.5" Width="7" Height="7" Fill="White"/>

                        <!-- Open mouth -->
