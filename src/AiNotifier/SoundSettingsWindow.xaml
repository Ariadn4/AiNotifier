<Window x:Class="AiNotifier.SoundSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="SoundSettingsWin"
        Width="420" Height="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Stop sound section -->
        <TextBlock x:Name="StopSectionLabel" Grid.Row="0" FontSize="13" FontWeight="SemiBold"
                   Foreground="#1E293B" Margin="0,0,0,8"/>
        <Border Grid.Row="1" Background="#f9fafb" BorderBrush="#e2e8f0" BorderThickness="1"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="StopSoundCombo" Width="200" Height="28" FontSize="12"
                          VerticalContentAlignment="Center" Cursor="Hand"/>
                <Button x:Name="StopPreviewBtn" Width="50" Height="28"
                        Margin="8,0,0,0" FontSize="12" Cursor="Hand"
                        Background="#f3f4f6" Foreground="#374151"
                        BorderBrush="#d1d5db" BorderThickness="1"
                        Click="StopPreview_Click"/>
                <Button x:Name="StopCustomBtn" Width="60" Height="28"
                        Margin="8,0,0,0" FontSize="12" Cursor="Hand"
                        Background="#f3f4f6" Foreground="#6b7280"
                        BorderBrush="#d1d5db" BorderThickness="1"
                        Click="StopCustom_Click"/>
            </StackPanel>
        </Border>

        <!-- Notification sound section -->
        <TextBlock x:Name="NotifSectionLabel" Grid.Row="2" FontSize="13" FontWeight="SemiBold"
                   Foreground="#1E293B" Margin="0,0,0,8"/>
        <Border Grid.Row="3" Background="#f9fafb" BorderBrush="#e2e8f0" BorderThickness="1"
                CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="NotifSoundCombo" Width="200" Height="28" FontSize="12"
                          VerticalContentAlignment="Center" Cursor="Hand"/>
                <Button x:Name="NotifPreviewBtn" Width="50" Height="28"
                        Margin="8,0,0,0" FontSize="12" Cursor="Hand"
                        Background="#f3f4f6" Foreground="#374151"
                        BorderBrush="#d1d5db" BorderThickness="1"
                        Click="NotifPreview_Click"/>
                <Button x:Name="NotifCustomBtn" Width="60" Height="28"
                        Margin="8,0,0,0" FontSize="12" Cursor="Hand"
                        Background="#f3f4f6" Foreground="#6b7280"
                        BorderBrush="#d1d5db" BorderThickness="1"
                        Click="NotifCustom_Click"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelBtn" Width="70" Height="30"
                    Click="Cancel_Click"
                    Background="#f3f4f6" Foreground="#6b7280"
                    BorderBrush="#d1d5db" BorderThickness="1"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button x:Name="OKBtn" Width="70" Height="30"
                    Click="OK_Click"
                    Background="#0284c7" Foreground="White"
                    BorderBrush="#0284c7" BorderThickness="1"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
